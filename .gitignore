*.tsbuildinfo
next-env.d.ts


# Operator-only routing config — NEVER commit (ADR-0001 D1)
docs/ops/product-routes.json
product-routes.json

# oh-my-agent runtime (local artifacts — do not commit)
.antigravitycli/
.agents/results/
.agents/state/

.agents/backup/
.migration-backup/
